# yt-Z-Downloader — environment variables
# Copy to .env and edit before running

# Storage paths (used inside Docker container)
DOWNLOAD_PATH=/downloads
COOKIES_PATH=/cookies
DATA_PATH=/data

# Queue
MAX_QUEUE_SIZE=50
MAX_RETRIES=3

# Defaults
DEFAULT_FORMAT=mp4

# Optional: set to require X-API-Key header on all endpoints
# Leave empty to disable auth (default for local self-hosted use)
API_KEY=

# Server
HOST=0.0.0.0
PORT=8080
