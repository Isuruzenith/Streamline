{
  "name": "streamline-md",
  "version": "1.4.0",
  "description": "Streamline - an open-source WebUI for yt-dlp.",
  "author": "FlameonLabs",
  "type": "module",
  "keywords": [
    "yt-dlp",
    "youtube-downloader",
    "media-downloader",
    "video-downloader",
    "webui",
    "bun",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flameonlabs/streamline.git"
  },
  "homepage": "https://github.com/flameonlabs/streamline#readme",
  "bugs": {
    "url": "https://github.com/flameonlabs/streamline/issues"
  },
  "bin": {
    "streamline-md": "bin/streamline.js"
  },
  "scripts": {
    "dev": "concurrently -n fe,be -c cyan,green \"bun run dev:frontend\" \"bun run dev:backend\"",
    "dev:frontend": "vite --port 5200",
    "dev:backend": "bun --watch server/index.js",
    "build": "vite build",
    "ci": "bun run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:server": "bun test server/test/",
    "prepublishOnly": "bun run build",
    "start": "bun server/index.js",
    "postinstall": "bun scripts/provision.js"
  },
  "files": [
    "bin/streamline.js",
    "dist",
    "server/index.js",
    "server/routes",
    "server/services",
    "server/ws",
    "scripts/provision.js",
    "README.md",
    "CHANGELOG.md",
    "package.json"
  ],
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.2.0",
    "@elysiajs/static": "^1.2.0",
    "clsx": "^2.1.0",
    "elysia": "^1.2.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.5"
  }
}
