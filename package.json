{
  "name": "streamline",
  "version": "0.1.0",
  "description": "Open-source WebUI for yt-dlp — paste a URL, download anything.",
  "type": "module",
  "bin": {
    "streamline": "./bin/streamline.js"
  },
  "scripts": {
    "dev": "concurrently -n fe,be -c cyan,green \"bun run dev:frontend\" \"bun run dev:backend\"",
    "dev:frontend": "vite --port 5173",
    "dev:backend": "bun --watch server/index.js",
    "build": "vite build",
    "ci": "bun run build",
    "prepublishOnly": "bun run build",
    "start": "bun server/index.js",
    "postinstall": "bun scripts/provision.js"
  },
  "files": [
    "bin",
    "dist",
    "server",
    "scripts",
    "public",
    "docs",
    "README.md",
    "package.json"
  ],
  "dependencies": {
    "elysia": "^1.2.0",
    "@elysiajs/cors": "^1.2.0",
    "@elysiajs/static": "^1.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.6.0",
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^6.0.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "@types/bun": "^1.0.0"
  }
}
